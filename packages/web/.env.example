#
# NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
# NEXT_PUBLIC_CHAIN_ID=42220
# NEXT_PUBLIC_ESCROW_ADDRESS=0x44E4Aafb22ac1Af3ea005EBa7384Fa310b6fA671  # ADR-057 redeploy (old 0x0890… retired)
# NEXT_PUBLIC_DISPUTE_ADDRESS=0x6d5Aa5e0EAE407688E99492213849D9a608D63d2
# NEXT_PUBLIC_STAKE_ADDRESS=0x3D588192BC76e38a3f6453E45A9B9aD0Dc85bc9A
# NEXT_PUBLIC_REPUTATION_ADDRESS=0xaF890609a3B2AF6E1E2Ebf91267347133b5065AD
# NEXT_PUBLIC_VOTING_ADDRESS=0xa1C48f2f962484D63D4D1b04C9c2574Da2C0EcBA
# NEXT_PUBLIC_USDT_ADDRESS=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
# NEXT_PUBLIC_CREDITS_ADDRESS=0xDDbE5BEC28B4eC0a309fca87047750EF4b42F7d6

# === ngrok dev mode (optional, only for MiniPay Developer Mode testing) ===
# When testing in MiniPay via ngrok tunnel:
#   1. Start ngrok:    ngrok http 3000
#   2. Run helper:     .\scripts\dev-ngrok.ps1
#      The helper auto-fills NEXT_PUBLIC_BASE_URL with the ngrok HTTPS URL,
#      empties NEXT_PUBLIC_API_URL so /api/* fetches go relative, and sets
#      LOCAL_API_REWRITE_TARGET below — Next.js rewrites then proxy to it.
# Production builds: leave LOCAL_API_REWRITE_TARGET unset.
LOCAL_API_REWRITE_TARGET=

# === MiniPay detection override (optional dev/test) ===
# When set to "true", forces detectMiniPay() to return true on every
# call, swapping HomeRouter to HomeMiniPay + lifting the MiniPay-only
# gates on /marketplace, /seller/dashboard, /checkout. Useful to
# preview the MiniPay flow on a desktop browser without needing the
# MiniPay app, and to unblock Mini App Test mode where the canonical
# window.ethereum.isMiniPay flag is not always injected.
# Production builds: leave unset.
# NEXT_PUBLIC_FORCE_MINIPAY=true

# === MiniPay detection debug overlay (optional dev/test) ===
# When set to "true", mounts the DebugMiniPayOverlay on HomeRouter
# (bottom-right) showing the 4 detection signals + final result of
# detectMiniPay(). Empirical diagnostic for next regression on the
# detection ladder — eliminates DevTools console round-trips on
# tunneled MiniPay Test mode WebViews.
# Production builds: leave unset (component returns null when unset,
# tree-shake kicks in on prod build).
# NEXT_PUBLIC_DEBUG_MINIPAY=true

# === Marketing tab visibility (ADR-049 V1 pivot) ===
# V1 default `false` hides the 5-template marketing pack tab from the
# seller dashboard nav. The photo-enhancement feature lives in the
# add-product dialog instead. The MarketingTab UI + endpoints stay
# in the codebase for V1.5+ reactivation. Set to "true" only for
# preview / V1.5 phased rollout.
# NEXT_PUBLIC_ENABLE_MARKETING_TAB=false

# === Fee abstraction CIP-64 (ADR-003 + MiniPay submission requirement) ===
# When set to "true" AND chainId === 42220 (Celo mainnet), the
# checkout / dispute / refund / confirm hooks emit CIP-64 (type 0x7b)
# transactions with feeCurrency = USDT adapter (0x0E2A3e05bc9A16F5292A6170456A710cb89C6f72).
# Buyers pay the network fee in USDT instead of CELO — required by
# MiniPay (the wallet never exposes CELO to users).
# On Sepolia or with this flag off, txs fall back to legacy (type 0).
# Default unset = legacy. Flip on with the J12 mainnet deploy.
# NEXT_PUBLIC_FEE_ABSTRACTION_ENABLED=true

# === WalletConnect project ID (ADR-052 Phase 2) ===
# Free project ID from https://cloud.walletconnect.com — enables
# mobile-Chrome buyers without a wallet extension to connect via
# Valora / MetaMask Mobile / Trust / any WC-compatible wallet app.
# Leave unset to skip registering the connector (the build stays
# clean and "Get MiniPay" remains the only path for mobile Chrome).
# NEXT_PUBLIC_WC_PROJECT_ID=

# === Address book route visibility (ADR-050 V1 inline checkout pivot) ===
# V1 default `false` hides /profile/addresses (404). The checkout flow
# uses InlineDeliveryAddressForm instead — buyers type the address
# directly on the checkout page. The AddressBookPage + AddressFormModal
# + /api/v1/me/addresses CRUD endpoints stay in the codebase for V1.5+
# reactivation as a power-user feature. Set to "true" only for preview
# / V1.5 phased rollout.
# NEXT_PUBLIC_ENABLE_ADDRESS_BOOK=false
