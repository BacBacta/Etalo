# Etalo web — single Next.js app at etalo.app (ADR-035)
# Serves both public funnel surface and Mini App surface (MiniPay detection).

# Backend API (V2 FastAPI). Includes the /api/v1 prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Canonical URL of this app — metadataBase, og:url, sitemap base.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Celo Sepolia chain (V2 contracts deployed at v2.0.0-contracts-sepolia).
NEXT_PUBLIC_CELO_RPC_URL=https://celo-sepolia.drpc.org
NEXT_PUBLIC_CHAIN_ID=11142220

# V2 contract addresses (Celo Sepolia testnet).
# Source: packages/contracts/deployments/celo-sepolia-v2.json
NEXT_PUBLIC_ESCROW_ADDRESS=0x6caEBc6aDc5082f6B63282e86CaF51AEbd630bfb
NEXT_PUBLIC_DISPUTE_ADDRESS=0x863F0bBc8d5873fE49F6429A8455236fE51A9aBE
NEXT_PUBLIC_STAKE_ADDRESS=0xBB21BAA78f5b0C268eA66912cE8B3E76eB79c417
NEXT_PUBLIC_REPUTATION_ADDRESS=0x2a6639074d0897c6280f55b252B97dd1c39820b7
NEXT_PUBLIC_VOTING_ADDRESS=0x335Ac0998667F76FE265BC28e6989dc535A901E7
NEXT_PUBLIC_USDT_ADDRESS=0x5ce5EBA46a72EA49655367c57334E038Ea1Aa1f3
# Sprint J7 Block 5b deploy (EtaloCredits — credits purchase contract).
NEXT_PUBLIC_CREDITS_ADDRESS=0xb201a5F0D471261383F8aFbF07a9dc6584C7B60d

# === ngrok dev mode (optional, only for MiniPay Developer Mode testing) ===
# When testing in MiniPay via ngrok tunnel:
#   1. Start ngrok:    ngrok http 3000
#   2. Run helper:     .\scripts\dev-ngrok.ps1
#      The helper auto-fills NEXT_PUBLIC_BASE_URL with the ngrok HTTPS URL,
#      empties NEXT_PUBLIC_API_URL so /api/* fetches go relative, and sets
#      LOCAL_API_REWRITE_TARGET below — Next.js rewrites then proxy to it.
# Production builds: leave LOCAL_API_REWRITE_TARGET unset.
LOCAL_API_REWRITE_TARGET=

# === MiniPay detection override (optional dev/test) ===
# When set to "true", forces detectMiniPay() to return true on every
# call, swapping HomeRouter to HomeMiniPay + lifting the MiniPay-only
# gates on /marketplace, /seller/dashboard, /checkout. Useful to
# preview the MiniPay flow on a desktop browser without needing the
# MiniPay app, and to unblock Mini App Test mode where the canonical
# window.ethereum.isMiniPay flag is not always injected.
# Production builds: leave unset.
# NEXT_PUBLIC_FORCE_MINIPAY=true

# === MiniPay detection debug overlay (optional dev/test) ===
# When set to "true", mounts the DebugMiniPayOverlay on HomeRouter
# (bottom-right) showing the 4 detection signals + final result of
# detectMiniPay(). Empirical diagnostic for next regression on the
# detection ladder — eliminates DevTools console round-trips on
# tunneled MiniPay Test mode WebViews.
# Production builds: leave unset (component returns null when unset,
# tree-shake kicks in on prod build).
# NEXT_PUBLIC_DEBUG_MINIPAY=true
