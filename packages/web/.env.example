# Etalo web — single Next.js app at etalo.app (ADR-035)
# Serves both public funnel surface and Mini App surface (MiniPay detection).

# Backend API (V2 FastAPI). Includes the /api/v1 prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Canonical URL of this app — metadataBase, og:url, sitemap base.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================
# Chain config — DEFAULTS = Celo Sepolia (testnet) for local dev safety.
# Production deploy : override every NEXT_PUBLIC_* below with the
# MAINNET values (see "MAINNET overrides" section + docs/MAINNET_CUTOVER.md).
# =============================================================

# Celo Sepolia chain (V2 contracts post-Pashov-audit redeploy
# 2026-05-25, ADR-054, tag v1.3-audit-fixes).
# Source: packages/contracts/deployments/celo-sepolia-v2.json
NEXT_PUBLIC_CELO_RPC_URL=https://celo-sepolia.drpc.org
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_ESCROW_ADDRESS=0xc8174b1218fEbD7d49B982cB3f1De83e411FbEA1
NEXT_PUBLIC_DISPUTE_ADDRESS=0x1f830A47af07E2BE9Db2017C873Bd2eF7F98f4a1
NEXT_PUBLIC_STAKE_ADDRESS=0xE599a167f0422D6700EC812c6b0f3c485379Ed05
NEXT_PUBLIC_REPUTATION_ADDRESS=0x5762502acAA57744F0bC10b3f0fD2Cd59a16EFbE
NEXT_PUBLIC_VOTING_ADDRESS=0x44E4Aafb22ac1Af3ea005EBa7384Fa310b6fA671
NEXT_PUBLIC_USDT_ADDRESS=0xd34428140Fc8D6Be523d9A14C4E215F5709f9427
# Sprint J7 Block 5b deploy (EtaloCredits — credits purchase contract).
NEXT_PUBLIC_CREDITS_ADDRESS=0x778a6bda524F4D396F9566c0dF131F76b0E15CA3

# =============================================================
