# Supply-chain hardening — required for the MiniPay Mini App listing
# review (docs/MINIPAY_LISTING.md §2 "Dependency security").

# Never run install/post-install scripts from dependencies. The single
# highest-value defense against a compromised transitive package
# executing arbitrary code at `npm install` time.
ignore-scripts=true

# Any new dependency added via `npm install <pkg>` is written to
# package.json as an EXACT version (no ^/~ range). All current deps are
# already pinned exactly; this keeps that invariant going forward.
save-exact=true

# NOTE on the 7-day "minimum release age" MiniPay asks for:
# `minimumReleaseAge` is a pnpm-only setting and is NOT honored by npm
# (this package uses npm — package-lock.json + `npm ci`). The
# equivalent guarantee here is: exact-pinned versions + a committed
# lockfile + `npm ci` in CI => fully reproducible, no silent upgrades.
# New deps are reviewed manually for published age before adding.
