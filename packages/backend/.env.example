# Database
# - Local dev: `docker compose up -d postgres` then keep the URL below.
# - Prod: DATABASE_URL is injected as a Fly secret by `fly postgres
#   attach --app etalo-api etalo-db` (see packages/backend/fly.toml).
#   Do not set it manually in prod.
DATABASE_URL=postgresql://etalo:etalo@localhost:5432/etalo

# Redis (Upstash)
REDIS_URL=rediss://default:xxxxx@your-instance.upstash.io:6379

# JWT
JWT_SECRET=generate-a-32-char-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Cart token HMAC secret (Block 6 — POST /api/v1/cart/checkout-token).
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
CART_TOKEN_SECRET=generate-a-32-char-cart-token-secret-here

# Security — when true, reject the temporary X-Wallet-Address header
# used by some routes during dev. MUST be true in production.
# See docs/DECISIONS.md 2026-04-22.
ENFORCE_JWT_AUTH=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment (development | production)
ENVIRONMENT=development

# Pinata IPFS — use Pinata's own naming (PINATA_API_SECRET not _KEY).
# PINATA_JWT is preferred by Pinata and will be wired in a later pass;
# the PINATA_API_KEY + PINATA_API_SECRET pair is still accepted.
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Frontend base URL — used by WhatsApp notifications to deep-link
# buyers at /orders/[id] (J11.5 Block 7, ADR-043). Pick the pattern
# that matches your dev setup :
#   Production (default if unset)
#     FRONTEND_BASE_URL=https://etalo.app
#   Local dev with ngrok reserved domain
#     # FRONTEND_BASE_URL=https://upright-henna-armless.ngrok-free.dev
#   Local dev without ngrok (limited — WhatsApp can't reach localhost)
#     # FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=https://etalo.app

# Anthropic Claude API (Sprint J7 Block 4 — marketing caption generation).
# Get a key at https://console.anthropic.com. When unset, asset_generator
# falls back to a deterministic local caption so dev flows still work.
ANTHROPIC_API_KEY=

# Celo RPC
CELO_RPC_URL=https://celo-sepolia.drpc.org
ESCROW_CONTRACT_ADDRESS=0x652e0278f4a1b7915dc89f53ab3e5c35696cb455
DISPUTE_CONTRACT_ADDRESS=0x438ed447c5467abb6395b56a88bfec7a80c489e9
REPUTATION_CONTRACT_ADDRESS=0xc9d3f823a4c985bd126899573864dba4a6601ef4
# MockUSDT on testnet. Swap for Celo mainnet USDT
# (0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e) in production.
USDT_CONTRACT_ADDRESS=0x4212d248fc28c7aa0ae0e5982051b5e9d2a12dc6

# ADR-019 auto-refund keeper (Block 2). Hex private key (with or
# without 0x prefix) of a wallet funded with CELO ; used by the
# backend keeper to call `EtaloEscrow.triggerAutoRefundIfInactive`
# for orders past the 7-day seller-inactivity deadline.
#
# NEVER put a real key in `.env.example` — it would be committed
# to git and is therefore compromised. Real keys go in :
#   Local dev :  packages/backend/.env (gitignored)
#   Production : `fly secrets set RELAYER_PRIVATE_KEY=0x... -a etalo-api`
#
# Empty value disables the keeper (the contract function is permissionless,
# so buyers can still self-claim from /orders/[id]).
RELAYER_PRIVATE_KEY=
# Polling interval. 6h is enough — the deadline is 7d so worst-case
# extra delay is 12h with one missed cycle. Set 0.05 (~3 min) in dev.
AUTO_REFUND_KEEPER_INTERVAL_HOURS=6.0
AUTO_REFUND_KEEPER_ENABLED=true
