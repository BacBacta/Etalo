# Database (Supabase pooler URL with SSL)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xx.pooler.supabase.com:6543/postgres?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:xxxxx@your-instance.upstash.io:6379

# JWT
JWT_SECRET=generate-a-32-char-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment (development | production)
ENVIRONMENT=development

# Pinata IPFS
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Celo RPC
CELO_RPC_URL=https://celo-sepolia.drpc.org
ESCROW_CONTRACT_ADDRESS=0x652e0278f4a1b7915dc89f53ab3e5c35696cb455
DISPUTE_CONTRACT_ADDRESS=0x438ed447c5467abb6395b56a88bfec7a80c489e9
REPUTATION_CONTRACT_ADDRESS=0xc9d3f823a4c985bd126899573864dba4a6601ef4
