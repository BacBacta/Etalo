# Database (Supabase pooler URL with SSL)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xx.pooler.supabase.com:6543/postgres?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:xxxxx@your-instance.upstash.io:6379

# JWT
JWT_SECRET=generate-a-32-char-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Cart token HMAC secret (Block 6 — POST /api/v1/cart/checkout-token).
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
CART_TOKEN_SECRET=generate-a-32-char-cart-token-secret-here

# Security — when true, reject the temporary X-Wallet-Address header
# used by some routes during dev. MUST be true in production.
# See docs/DECISIONS.md 2026-04-22.
ENFORCE_JWT_AUTH=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment (development | production)
ENVIRONMENT=development

# Pinata IPFS — use Pinata's own naming (PINATA_API_SECRET not _KEY).
# PINATA_JWT is preferred by Pinata and will be wired in a later pass;
# the PINATA_API_KEY + PINATA_API_SECRET pair is still accepted.
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Celo RPC
CELO_RPC_URL=https://celo-sepolia.drpc.org
ESCROW_CONTRACT_ADDRESS=0x652e0278f4a1b7915dc89f53ab3e5c35696cb455
DISPUTE_CONTRACT_ADDRESS=0x438ed447c5467abb6395b56a88bfec7a80c489e9
REPUTATION_CONTRACT_ADDRESS=0xc9d3f823a4c985bd126899573864dba4a6601ef4
# MockUSDT on testnet. Swap for Celo mainnet USDT
# (0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e) in production.
USDT_CONTRACT_ADDRESS=0x4212d248fc28c7aa0ae0e5982051b5e9d2a12dc6
