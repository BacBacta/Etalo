# ============================================
# Etalo — Root Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database (Supabase PostgreSQL) ---
POSTGRES_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xx.pooler.supabase.com:6543/postgres

# --- Redis (Upstash) ---
REDIS_URL=rediss://default:xxxxx@your-instance.upstash.io:6379

# --- JWT ---
JWT_SECRET=generate-a-32-char-secret-here

# --- Blockchain (Celo) ---
PRIVATE_KEY=your_deployer_private_key_without_0x
CELOSCAN_API_KEY=your_celoscan_api_key

# --- IPFS (Pinata) ---
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
